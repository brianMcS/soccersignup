# PostgreSQL
POSTGRES_DB=soccersignup
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-local-password

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# Application
# Use a random secret of at least 32 bytes. Do not reuse this example value.
APP_JWT_SECRET=replace-with-a-random-secret-of-at-least-32-bytes
APP_FRONTEND_ORIGIN=http://localhost:4200
